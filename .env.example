STUDENT_ID=30225
LOG_LEVEL=INFO
TZ=Asia/Dhaka

POSTGRES_USER=smile
POSTGRES_PASSWORD=change_me
POSTGRES_DB=smiledb

# Inside Docker the app overrides these to db:5432.
# For local development set POSTGRES_HOST=localhost and match POSTGRES_PORT
# to POSTGRES_PORT_HOST below.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Change any of these if the port is already taken on your machine.
POSTGRES_PORT_HOST=15432
APP_PORT=8000
PGADMIN_PORT=5051

# pgAdmin rejects addresses ending in .local, so use a real TLD.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Local development only; the container sets its own absolute paths.
BASE_DIR=.
DATA_DIR=data
MODEL_DIR=models
SEED_DIR=seed